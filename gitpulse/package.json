{
  "name": "gitpulse",
  "version": "1.0.0",
  "description": "AI-powered terminal code reviewer for your staged git diffs, powered by Groq.",
  "type": "module",
  "bin": {
    "gitpulse": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --clean --shims",
    "dev": "tsup src/cli.ts --format esm --target node20 --watch --shims",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "cli",
    "git",
    "code-review",
    "ai",
    "groq",
    "llm",
    "developer-tools",
    "static-analysis",
    "pre-push",
    "devtools"
  ],
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "groq-sdk": "^0.7.0",
    "ora": "^8.0.1",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
